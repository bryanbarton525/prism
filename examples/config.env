# Prism process settings (env format). Point PRISM_CONFIG_FILE at this file:
#   export PRISM_CONFIG_FILE="$HOME/.prism/config.env"
# Every key can also be supplied directly as an environment variable.

# ── Root + directories ────────────────────────────────────────────────
# Root may be a local path or a GitHub repo URL.
PRISM_ROOT=https://github.com/owner/repo
# Optional overrides; default to <root>/agents and <root>/skills.
# PRISM_AGENT_DIR=/abs/path/to/agents
# PRISM_SKILLS_DIR=/abs/path/to/skills
# PRISM_STATE_DIR=/abs/path/to/state

# ── Model runtime ─────────────────────────────────────────────────────
# Default path: local Ollama. Leave the runtime engine unset to use Ollama.
PRISM_OLLAMA_HOST=http://127.0.0.1:11434

# To run agents on SGLang (or any OpenAI-compatible runtime) instead,
# set the engine + base URL below. When set, this replaces Ollama for all agents.
# PRISM_MODEL_RUNTIME_ENGINE=sglang
# PRISM_MODEL_RUNTIME_BASE_URL=http://localhost:30000/v1
# PRISM_MODEL_RUNTIME_API_KEY=
# PRISM_MODEL_RUNTIME_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# Optional fallback runtime if the primary is unavailable.
# PRISM_MODEL_RUNTIME_FALLBACK_ENGINE=ollama
# PRISM_MODEL_RUNTIME_FALLBACK_BASE_URL=http://127.0.0.1:11434
# PRISM_MODEL_RUNTIME_FALLBACK_API_KEY=
# PRISM_MODEL_RUNTIME_FALLBACK_MODEL=qwen2.5-coder:7b

# ── Integrations ──────────────────────────────────────────────────────
# GitHub token (any of these names work; PRISM_GITHUB_TOKEN preferred).
# PRISM_GITHUB_TOKEN=ghp_xxx
# Downstream Linear MCP endpoint used by the linear agent/skill.
PRISM_LINEAR_MCP_URL=https://mcp.linear.app/mcp

# ── Observability + policy ────────────────────────────────────────────
# Event store location for run telemetry.
# PRISM_EVENT_STORE=/abs/path/to/events
# Bounded allow/deny policy (see prism-policy.json in this folder).
PRISM_POLICY_FILE=~/.prism/prism-policy.json
